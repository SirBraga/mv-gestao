// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tickets       Tickets[]
  apontamentos  Apontamento[]
  comments      TicketComment[]
  sessions      Session[]
  accounts      Account[]
  onlineStatus     UserStatus?
  notifications    Notification[]
  pushSubscription String?
  
  // Chat relations
  createdChannels  ChatChannel[]   @relation("ChannelCreator")
  channelMembers   ChannelMember[]
  chatMessages     ChatMessage[]
  chatMediaFiles   ChatMediaFile[]
  knowledgeArticlesCreated KnowledgeBaseArticle[] @relation("KnowledgeArticleCreatedBy")
  knowledgeArticlesUpdated KnowledgeBaseArticle[] @relation("KnowledgeArticleUpdatedBy")

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Clients {
  id String @id 
  name String
  razaoSocial String?
  nomeFantasia String?
  cnpj String?
  cpf String?
  ie String?
  state String?
  codigoCSC String?
  tokenCSC String?
  aditionalInfo String?
  address String
  city String
  houseNumber String
  neighborhood String
  zipCode String
  complement String
  cnae String?
  businessSector String?
  type CType? @default(PESSOA_JURIDICA)
  contabilityId String?
  contability Contability? @relation(fields: [contabilityId], references: [id])
  tickets Tickets[]
  products Products[]
  clientProducts ClientProduct[]
  contacts ClientContact[]
  attachments Attachment[]
  clientProductSerials ClientProductSerial[]
  hasContract Boolean?
  contractType ContractType?
  supportReleased Boolean?
  contractCancelReason String?
  contractCancelDate DateTime?
  blockReason BlockReason?
  photoUrl String?
  ownerName String?
  ownerPhone String?
  ownerEmail String?
  ownerCpf String?
  certificateExpiresDate DateTime?
  certificateType String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clients")
}

model ClientContact {
  id              String   @id @default(cuid())
  clientId        String
  client          Clients  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name            String
  phone           String?
  email           String?
  role            String?  // e.g. "Suporte", "Financeiro", "Proprietário"
  bestContactTime String?  // Melhor horário para contato
  isDefault       Boolean  @default(false)
  ticketsRequested Tickets[] @relation("RequestedByContact")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([clientId])
  @@map("client_contact")
}


model Tickets {
  id           Int    @id @default(autoincrement())
  ticketNumber Int    @default(autoincrement())
  clientId String
  client Clients @relation(fields: [clientId], references: [id])
  ticketStatus Ticket_Status? @default(NOVO)
  ticketPriority Ticket_Priority? @default(MEDIUM)
  ticketType Ticket_Type? @default(SUPPORT)
  ticketDescription String
  ticketResolutionDate DateTime?
  reopenCount Int @default(0)
  reopenReason String?
  cancelReason String?
  reopenDate DateTime?
  reopenById String?
  apontamentos Apontamento[]
  comments TicketComment[]
  schedules TicketSchedule[]
  attachments Attachment[]
  assignedTo User? @relation(fields: [assignedToId], references: [id], onDelete: Cascade)
  assignedToId String?
  // Solicitante: pode ser um contato do cliente ou uma contabilidade
  requestedByContactId String?
  requestedByContact   ClientContact? @relation("RequestedByContact", fields: [requestedByContactId], references: [id])
  requestedByContabilityId String?
  requestedByContability   Contability? @relation("RequestedByContability", fields: [requestedByContabilityId], references: [id])
  knowledgeArticleId String?
  knowledgeArticle KnowledgeBaseArticle? @relation(fields: [knowledgeArticleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tickets")
}


model Apontamento {
  id String @id @default(cuid())
  ticketId Int
  ticket Tickets @relation(fields: [ticketId], references: [id])
  userId String
  user User @relation(fields: [userId], references: [id])
  description String
  category Apontamento_Category @default(PROBLEMA_RESOLVIDO)
  duration Int // duration in minutes
  date DateTime @default(now())
  statusChange Ticket_Status? // optional: change ticket status with this entry
  attachments Attachment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("apontamento")
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId  Int
  ticket    Tickets  @relation(fields: [ticketId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  parentId  String?
  parent    TicketComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   TicketComment[] @relation("CommentReplies")
  attachments Attachment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ticket_comment")
}

model TicketSchedule {
  id         String                 @id @default(cuid())
  ticketId   Int
  ticket     Tickets                @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  title      String
  description String?
  type       Ticket_Schedule_Type
  format     Ticket_Schedule_Format
  scheduledAt DateTime
  durationMinutes Int?
  location   String?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  @@index([ticketId, scheduledAt])
  @@map("ticket_schedule")
}

model Contability {
  id String @id @default(cuid())
  name String?
  razaoSocial String?
  nomeFantasia String?
  phone String?
  email String?
  address String?
  city String?
  houseNumber String?
  neighborhood String?
  zipCode String?
  complement String?
  state String?
  cnpj String?
  cpf String?
  ie String?
  type CType? @default(PESSOA_JURIDICA)
  clients Clients[]
  contacts ContabilityContact[]
  ticketsRequested Tickets[] @relation("RequestedByContability")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contability")
}

model ContabilityContact {
  id              String   @id @default(cuid())
  contabilityId   String
  contability     Contability @relation(fields: [contabilityId], references: [id], onDelete: Cascade)
  name            String
  phone           String?
  email           String?
  role            String?
  bestContactTime String?
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([contabilityId])
  @@map("contability_contact")
}


model Products {
  id String @id @default(cuid())
  name String
  description String?
  clientId String?
  client   Clients? @relation(fields: [clientId], references: [id])
  image String?
  category String?
  status String?
  supportContact String?
  priceMonthly    Float?  // Preço mensal
  priceQuarterly  Float?  // Preço trimestral
  priceYearly     Float?  // Preço anual
  hasSerialControl Boolean @default(false)  // Controla se produto exige serial
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productPlugins ProductPlugin[]
  clientProducts ClientProduct[]
  clientProductSerials ClientProductSerial[]
  knowledgeArticles KnowledgeBaseArticleProduct[]

  @@map("products")
}

model ProductPlugin {
  id String @id @default(cuid())
  productId String
  product Products @relation(fields: [productId], references: [id], onDelete: Cascade)
  name String
  description String?
  status String?
  priceMonthly Float?
  priceQuarterly Float?
  priceYearly Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientProductPlugins ClientProductPlugin[]

  @@unique([productId, name])
  @@map("product_plugins")
}

model ClientProduct {
  id String @id @default(cuid())
  clientId String
  client Clients @relation(fields: [clientId], references: [id], onDelete: Cascade)
  productId String
  product Products @relation(fields: [productId], references: [id], onDelete: Cascade)
  installationType InstallationType?
  priceMonthly Float?
  priceQuarterly Float?
  priceYearly Float?
  notes String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serials ClientProductSerial[]
  plugins ClientProductPlugin[]

  @@unique([clientId, productId])
  @@index([productId])
  @@map("client_products")
}

model ClientProductPlugin {
  id String @id @default(cuid())
  clientProductId String
  clientProduct ClientProduct @relation(fields: [clientProductId], references: [id], onDelete: Cascade)
  productPluginId String
  productPlugin ProductPlugin @relation(fields: [productPluginId], references: [id], onDelete: Cascade)
  priceMonthly Float?
  priceQuarterly Float?
  priceYearly Float?
  notes String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientProductId, productPluginId])
  @@index([productPluginId])
  @@map("client_product_plugins")
}

model KnowledgeBaseArticle {
  id String @id @default(cuid())
  title String
  slug String @unique
  summary String?
  content String
  category String?
  status String @default("RASCUNHO")
  difficulty String?
  isFeatured Boolean @default(false)
  viewCount Int @default(0)
  helpfulCount Int @default(0)
  createdById String?
  createdBy User? @relation("KnowledgeArticleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?
  updatedBy User? @relation("KnowledgeArticleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  products KnowledgeBaseArticleProduct[]
  tickets Tickets[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([category])
  @@map("knowledge_base_article")
}

model KnowledgeBaseArticleProduct {
  id String @id @default(cuid())
  articleId String
  article KnowledgeBaseArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  productId String
  product Products @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([articleId, productId])
  @@index([productId])
  @@map("knowledge_base_article_product")
}

model ClientProductSerial {
  id String @id @default(cuid())
  clientId String
  client Clients @relation(fields: [clientId], references: [id], onDelete: Cascade)
  productId String
  product Products @relation(fields: [productId], references: [id])
  clientProductId String?
  clientProduct ClientProduct? @relation(fields: [clientProductId], references: [id], onDelete: SetNull)
  serial String  // Número do serial
  expiresAt DateTime?  // Data de expiração do serial
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientProductId])
  @@unique([clientId, productId, serial])  // Um serial não pode se repetir para o mesmo cliente/produto
  @@map("client_product_serials")
}

enum Role {
  ADMIN
  MODERATOR
  USER
}

enum CType {
  PESSOA_FISICA
  PESSOA_JURIDICA
}

enum Ticket_Status {
  NOVO
  PENDING_CLIENT
  PENDING_EMPRESS
  IN_PROGRESS
  CLOSED
  CANCELLED
}

enum Ticket_Priority {
  LOW
  MEDIUM
  HIGH
}

enum Ticket_Type {
  SUPPORT
  SALES
  FINANCE
  MAINTENCE
}

enum Apontamento_Category {
  PROBLEMA_RESOLVIDO
  TREINAMENTO
  REUNIAO
  TIRA_DUVIDAS
  DESENVOLVIMENTO
}

enum ContractType {
  MENSAL
  ANUAL
  AVULSO
  CANCELADO
}

enum InstallationType {
  LOCAL
  SERVIDOR
  ONLINE
}

enum Ticket_Schedule_Type {
  TREINAMENTO
  TIRA_DUVIDAS
  CONSULTORIA
  IMPLANTACAO
  PARAMETRIZACAO
  REUNIAO_ALINHAMENTO
  VISITA_TECNICA
}

enum Ticket_Schedule_Format {
  PRESENCIAL
  ONLINE
}

enum BlockReason {
  CONTRATO_CANCELADO
  INADIMPLENCIA
  SOLICITACAO_CLIENTE
  OUTROS
}


model Attachment {
  id         String   @id @default(cuid())
  url        String
  fileName   String
  fileType   String   // e.g. "image/png", "application/pdf"
  fileSize   Int      // in bytes
  // Optional relations
  chatMessageId   String?
  chatMessage     ChatMessage? @relation(fields: [chatMessageId], references: [id], onDelete: Cascade)
  ticketId        Int?
  ticket          Tickets?     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  apontamentoId   String?
  apontamento     Apontamento? @relation(fields: [apontamentoId], references: [id], onDelete: Cascade)
  clientId        String?
  client          Clients?     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  commentId       String?
  comment         TicketComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([chatMessageId])
  @@index([ticketId])
  @@index([apontamentoId])
  @@index([clientId])
  @@index([commentId])
  @@map("attachment")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("TICKET_ASSIGNED") // TICKET_ASSIGNED, TICKET_COMMENT, etc.
  link      String?  // e.g. /dashboard/tickets/abc
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
  @@map("notification")
}

model UserStatus {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isOnline  Boolean  @default(false)
  lastSeen  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_status")
}

// ══════════════════════════════════════════════════════════════════════════════
// CHAT MODELS - Ably Integration
// ══════════════════════════════════════════════════════════════════════════════

model ChatChannel {
  id          String      @id @default(cuid())
  name        String
  description String?
  type        ChannelType @default(DIRECT)
  createdById String
  createdBy   User        @relation("ChannelCreator", fields: [createdById], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  members  ChannelMember[]
  messages ChatMessage[]

  @@index([createdById])
  @@map("chat_channels")
}

model ChannelMember {
  id        String     @id @default(cuid())
  channelId String
  channel   ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      MemberRole @default(MEMBER)
  joinedAt  DateTime   @default(now())
  mutedUntil DateTime?
  lastReadAt DateTime?

  @@unique([channelId, userId])
  @@index([userId])
  @@map("channel_members")
}

model ChatMessage {
  id        String      @id @default(cuid())
  channelId String
  channel   ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User        @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content   String
  type      MessageType @default(TEXT)
  
  // Media fields
  mediaUrl  String?
  mediaType String?
  fileName  String?
  fileSize  Int?
  
  // Reply fields
  replyToId String?
  replyTo   ChatMessage?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   ChatMessage[] @relation("MessageReplies")
  
  // Attachments
  attachments Attachment[]
  
  // Status
  isEdited  Boolean  @default(false)
  isDeleted Boolean  @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([channelId])
  @@index([senderId])
  @@index([replyToId])
  @@map("chat_messages")
}

model ChatMediaFile {
  id           String   @id @default(cuid())
  originalName String
  fileName     String
  mimeType     String
  size         Int
  url          String
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([uploadedById])
  @@map("chat_media_files")
}

enum ChannelType {
  DIRECT
  GROUP
  SUPPORT
  PROJECT
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  FILE
  SYSTEM
}